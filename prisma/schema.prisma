generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int                @id @default(autoincrement())
  email           String             @unique
  passwordHash    String
  name            String
  username        String             @unique
  phone           String?
  location        String?
  bio             String?
  farmName        String?
  avatarUrl       String?
  role            Role               @default(USER)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  aiConversations AiConversation[]
  comments        Comment[]
  diseaseAnalyses DiseaseAnalysis[]
  likes           Like[]
  priceReports    MarketPrice[]
  plantUploads    PlantImageUpload[]
  posts           Post[]
  sessions        Session[]
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Post {
  id        Int          @id @default(autoincrement())
  authorId  Int
  title     String
  content   String       @db.Text
  category  PostCategory @default(GENERAL)
  imageUrl  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  comments  Comment[]
  likes     Like[]
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([category])
  @@index([createdAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, authorId])
  @@index([authorId])
}

model Market {
  id        Int           @id @default(autoincrement())
  name      String
  city      String
  region    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  prices    MarketPrice[]

  @@unique([name, city], name: "name_city")
  @@index([city])
}

model Product {
  id        Int           @id @default(autoincrement())
  name      String
  category  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  prices    MarketPrice[]

  @@unique([name, category], name: "name_category")
  @@index([category])
}

model MarketPrice {
  id         Int       @id @default(autoincrement())
  marketId   Int
  productId  Int
  reporterId Int?
  price      Decimal   @db.Decimal(10, 2)
  unit       PriceUnit @default(KG)
  source     String?
  reportedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  market     Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  reporter   User?     @relation(fields: [reporterId], references: [id])

  @@index([marketId])
  @@index([productId])
  @@index([reportedAt])
  @@index([reporterId], map: "MarketPrice_reporterId_fkey")
}

model Subsidy {
  id          Int           @id @default(autoincrement())
  title       String
  institution String
  description String        @db.Text
  amount      String?
  region      String?
  status      SubsidyStatus @default(OPEN)
  opensAt     DateTime?
  closesAt    DateTime?
  link        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([closesAt])
}

model AiConversation {
  id        Int         @id @default(autoincrement())
  userId    Int?
  title     String
  topic     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User?       @relation(fields: [userId], references: [id])
  messages  AiMessage[]

  @@index([userId])
  @@index([createdAt])
}

model AiMessage {
  id             Int            @id @default(autoincrement())
  conversationId Int
  role           AiMessageRole
  content        String         @db.Text
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model PlantImageUpload {
  id        Int               @id @default(autoincrement())
  userId    Int?
  imageUrl  String
  crop      String?
  notes     String?
  createdAt DateTime          @default(now())
  analyses  DiseaseAnalysis[]
  user      User?             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model DiseaseAnalysis {
  id             Int               @id @default(autoincrement())
  userId         Int?
  uploadId       Int?
  crop           String?
  suspectedIssue String
  confidence     Int
  symptoms       Json
  recommendation String            @db.Text
  severity       String
  status         AnalysisStatus    @default(COMPLETED)
  createdAt      DateTime          @default(now())
  upload         PlantImageUpload? @relation(fields: [uploadId], references: [id])
  user           User?             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([uploadId])
  @@index([createdAt])
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum PostCategory {
  GENERAL
  QUESTION
  MARKET
  SUBSIDY
  DISEASE
}

enum SubsidyStatus {
  DRAFT
  OPEN
  CLOSING_SOON
  CLOSED
}

enum PriceUnit {
  KG
  T
  L
  PIECE
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
