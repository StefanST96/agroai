generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int                @id @default(autoincrement())
  email           String             @unique
  passwordHash    String
  name            String
  username        String             @unique
  phone           String?
  location        String?
  bio             String?
  farmName        String?
  avatarUrl       String?
  role            Role               @default(USER)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  aiConversations AiConversation[]
  comments        Comment[]
  diseaseAnalyses DiseaseAnalysis[]
  likes           Like[]
  priceReports    MarketPrice[]
  plantUploads    PlantImageUpload[]
  posts           Post[]
  sessions        Session[]
  mediaAssets     MediaAsset[]
  profile         UserProfile?
  createdBanners  SidebarBanner[]      @relation("BannerCreator")
  submittedReports ContentReport[]     @relation("ReportReporter")
  reportsAgainst  ContentReport[]      @relation("ReportTargetUser")
  resolvedReports ContentReport[]      @relation("ReportResolver")
  dismissedNotifications DismissedNotification[]
  weekendActivities WeekendActivity[]
}

model UserProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  displayName String?
  location    String?
  farmName    String?
  bio         String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Post {
  id        Int          @id @default(autoincrement())
  authorId  Int
  title     String
  content   String       @db.Text
  category  PostCategory @default(GENERAL)
  imageUrl  String?
  imageAssetId Int?
  videoAssetId Int?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  comments  Comment[]
  likes     Like[]
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  imageAsset MediaAsset? @relation("PostImage", fields: [imageAssetId], references: [id], onDelete: SetNull)
  videoAsset MediaAsset? @relation("PostVideo", fields: [videoAssetId], references: [id], onDelete: SetNull)
  reports    ContentReport[]

  @@index([authorId])
  @@index([category])
  @@index([createdAt])
  @@index([imageAssetId])
  @@index([videoAssetId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, authorId])
  @@index([authorId])
}

model Market {
  id        Int           @id @default(autoincrement())
  name      String
  city      String
  region    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  prices    MarketPrice[]

  @@unique([name, city], name: "name_city")
  @@index([city])
}

model Product {
  id        Int           @id @default(autoincrement())
  name      String
  category  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  prices    MarketPrice[]

  @@unique([name, category], name: "name_category")
  @@index([category])
}

model MarketPrice {
  id         Int       @id @default(autoincrement())
  marketId   Int
  productId  Int
  reporterId Int?
  price      Decimal   @db.Decimal(10, 2)
  unit       PriceUnit @default(KG)
  source     String?
  reportedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  market     Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  reporter   User?     @relation(fields: [reporterId], references: [id])

  @@index([marketId])
  @@index([productId])
  @@index([reportedAt])
  @@index([reporterId], map: "MarketPrice_reporterId_fkey")
}

model Subsidy {
  id          Int           @id @default(autoincrement())
  title       String
  institution String
  description String        @db.Text
  amount      String?
  region      String?
  status      SubsidyStatus @default(OPEN)
  opensAt     DateTime?
  closesAt    DateTime?
  link        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([closesAt])
}

model AiConversation {
  id        Int         @id @default(autoincrement())
  userId    Int?
  title     String
  topic     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User?       @relation(fields: [userId], references: [id])
  messages  AiMessage[]

  @@index([userId])
  @@index([createdAt])
}

model AiMessage {
  id             Int            @id @default(autoincrement())
  conversationId Int
  role           AiMessageRole
  content        String         @db.Text
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model PlantImageUpload {
  id        Int               @id @default(autoincrement())
  userId    Int?
  imageUrl  String?
  imageAssetId Int?
  crop      String?
  notes     String?
  createdAt DateTime          @default(now())
  analyses  DiseaseAnalysis[]
  user      User?             @relation(fields: [userId], references: [id])
  imageAsset MediaAsset?      @relation(fields: [imageAssetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([imageAssetId])
}

model MediaAsset {
  id          Int        @id @default(autoincrement())
  userId      Int?
  kind        MediaKind
  filename    String?
  mimeType    String
  size        Int
  data        Bytes      @db.LongBlob
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id])
  postImages  Post[]     @relation("PostImage")
  postVideos  Post[]     @relation("PostVideo")
  plantImages PlantImageUpload[]
  banners     SidebarBanner[]
  weekendActivityImages WeekendActivity[] @relation("WeekendActivityImage")

  @@index([userId])
  @@index([kind])
  @@index([createdAt])
}

model SidebarBanner {
  id           Int           @id @default(autoincrement())
  title        String
  body         String?       @db.Text
  ctaText      String?
  ctaHref      String?
  imageUrl     String?
  imageAssetId Int?
  variant      BannerVariant @default(CARD)
  position     Int           @default(0)
  isActive     Boolean       @default(true)
  createdById  Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    User?         @relation("BannerCreator", fields: [createdById], references: [id], onDelete: SetNull)
  imageAsset   MediaAsset?   @relation(fields: [imageAssetId], references: [id], onDelete: SetNull)

  @@index([isActive, position])
  @@index([createdById])
  @@index([imageAssetId])
}

model ContentReport {
  id             Int              @id @default(autoincrement())
  targetType     ReportTargetType
  reporterId     Int
  reportedUserId Int?
  postId         Int?
  reason         String
  details        String?          @db.Text
  status         ReportStatus     @default(OPEN)
  resolvedById   Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  reporter       User             @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser   User?            @relation("ReportTargetUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  post           Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  resolvedBy     User?            @relation("ReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([targetType, status])
  @@index([reporterId])
  @@index([reportedUserId])
  @@index([postId])
  @@index([createdAt])
}

model DismissedNotification {
  id               Int      @id @default(autoincrement())
  userId           Int
  notificationKey  String
  dismissedAt      DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationKey])
  @@index([userId])
  @@index([dismissedAt])
}

model DiseaseAnalysis {
  id             Int               @id @default(autoincrement())
  userId         Int?
  uploadId       Int?
  crop           String?
  suspectedIssue String
  confidence     Int
  symptoms       Json
  recommendation String            @db.Text
  severity       String
  status         AnalysisStatus    @default(COMPLETED)
  createdAt      DateTime          @default(now())
  upload         PlantImageUpload? @relation(fields: [uploadId], references: [id])
  user           User?             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([uploadId])
  @@index([createdAt])
}

model WeekendActivity {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  city        String
  location    String?
  category    String?
  imageUrl    String?
  imageAssetId Int?
  startAt     DateTime
  endAt       DateTime?
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  imageAsset  MediaAsset? @relation("WeekendActivityImage", fields: [imageAssetId], references: [id], onDelete: SetNull)

  @@index([startAt])
  @@index([city])
  @@index([createdById])
  @@index([imageAssetId])
}

model Partner {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  description String   @db.Text
  logoUrl     String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum PostCategory {
  GENERAL
  QUESTION
  MARKET
  SUBSIDY
  DISEASE
}

enum SubsidyStatus {
  DRAFT
  OPEN
  CLOSING_SOON
  CLOSED
}

enum PriceUnit {
  KG
  T
  L
  PIECE
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum BannerVariant {
  CARD
  HERO
}

enum ReportTargetType {
  POST
  PROFILE
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  REJECTED
}
